// MTPScript Test Example
// This file demonstrates various language features and constraints

// Basic arithmetic operations
let a = 10;
let b = 20;
let sum = a + b;
let product = a * b;
let difference = b - a;
let quotient = b / a;

// Console output effect
console.log("Hello, MTPScript!");
console.log("Sum:", sum);
console.log("Product:", product);

// Array operations
let numbers = [1, 2, 3, 4, 5];
let doubled = numbers.map(x => x * 2);
let filtered = numbers.filter(x => x > 3);

// Object operations
let person = {
    name: "Alice",
    age: 30,
    greet: function() {
        return "Hello, " + this.name;
    }
};

// Function definition
function fibonacci(n) {
    if (n <= 1) return n;
    return fibonacci(n - 1) + fibonacci(n - 2);
}

let fib10 = fibonacci(10);

