// Test: Error Handling (TECHSPEC §16)
// Tests typed error codes and deterministic error shapes

type ApiError =
    NotFound(string)
  | ValidationError(string)
  | Unauthorized
  | ServerError(string)

type ValidationResult = Valid | Invalid(List<string>)

api GET "/error-typed" uses {} {
  function handle_error(err: ApiError) {
    match err {
      NotFound(resource) => { "code": 404, "message": "Not found: " + resource }
      ValidationError(msg) => { "code": 400, "message": "Validation failed: " + msg }
      Unauthorized => { "code": 401, "message": "Unauthorized" }
      ServerError(msg) => { "code": 500, "message": "Server error: " + msg }
    }
  }
  const err1 = NotFound("user/123");
  const err2 = ValidationError("email is required");
  const err3 = Unauthorized;
  const err4 = ServerError("database connection failed");
  respond json({
    "not_found": handle_error(err1),
    "validation": handle_error(err2),
    "unauthorized": handle_error(err3),
    "server_error": handle_error(err4)
  })
}

api POST "/error-validation" uses {} {
  function validate_user(data: { name: string, email: string, age: number }) {
    function collect_errors(data: { name: string, email: string, age: number }, errors: List<string>) {
      const name_errors = if (data["name"] == "") { errors.push("name is required") } else { errors };
      const email_errors = if (data["email"] == "") { name_errors.push("email is required") } else { name_errors };
      const age_errors = if (data["age"] < 0) { email_errors.push("age must be positive") } else { email_errors };
      age_errors
    }
    const errors = collect_errors(data, []);
    if (errors.length == 0) { Valid } else { Invalid(errors) }
  }
  const valid_data = { "name": "Alice", "email": "alice@example.com", "age": 30 };
  const invalid_data = { "name": "", "email": "", "age": -5 };
  respond json({
    "valid_result": match validate_user(valid_data) {
      Valid => { "status": "valid" }
      Invalid(errs) => { "status": "invalid", "errors": errs }
    },
    "invalid_result": match validate_user(invalid_data) {
      Valid => { "status": "valid" }
      Invalid(errs) => { "status": "invalid", "errors": errs }
    }
  })
}

api GET "/error-result-chain" uses {} {
  function parse_id(s: string) {
    if (s == "1") { Ok(1) }
    else { if (s == "2") { Ok(2) }
    else { Err("invalid id: " + s) } }
  }
  function fetch_user(id: number) {
    if (id == 1) { Ok({ "id": 1, "name": "Alice" }) }
    else { Err("user not found: " + id) }
  }
  function process_request(id_str: string) {
    match parse_id(id_str) {
      Ok(id) => match fetch_user(id) {
        Ok(user) => Ok(user)
        Err(e) => Err(e)
      }
      Err(e) => Err(e)
    }
  }
  respond json({
    "valid_id_valid_user": match process_request("1") {
      Ok(u) => { "success": true, "user": u }
      Err(e) => { "success": false, "error": e }
    },
    "valid_id_no_user": match process_request("2") {
      Ok(u) => { "success": true, "user": u }
      Err(e) => { "success": false, "error": e }
    },
    "invalid_id": match process_request("abc") {
      Ok(u) => { "success": true, "user": u }
      Err(e) => { "success": false, "error": e }
    }
  })
}

api GET "/error-canonical-shape" uses {} {
  // Error shapes must be canonical JSON per TECHSPEC §16
  const standard_error = {
    "error": true,
    "code": "ERR_001",
    "message": "Something went wrong",
    "details": {
      "field": "email",
      "reason": "invalid format"
    }
  };
  const nested_error = {
    "error": true,
    "errors": [
      { "field": "name", "message": "required" },
      { "field": "email", "message": "invalid" },
      { "field": "age", "message": "must be positive" }
    ]
  };
  respond json({
    "standard": standard_error,
    "nested": nested_error,
    "standard_json": Json.stringify(standard_error),
    "nested_json": Json.stringify(nested_error)
  })
}

api POST "/error-recovery" uses {} {
  function safe_divide(a: number, b: number) {
    if (b == 0) { Err("division by zero") } else { Ok(a / b) }
  }
  function with_default(result: Result<number, string>, default_val: number) {
    match result {
      Ok(v) => v
      Err(_) => default_val
    }
  }
  const result1 = safe_divide(10, 2);
  const result2 = safe_divide(10, 0);
  respond json({
    "success": with_default(result1, 0),
    "with_default": with_default(result2, -1),
    "raw_error": match result2 {
      Ok(v) => { "value": v }
      Err(e) => { "error": e }
    }
  })
}
