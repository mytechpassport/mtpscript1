api GET "/lambdas-closures" uses {} {
  const add = function(x: number, y: number) { x + y };
  const sum = add(3, 4);

  const multiplier = 2;
  const mul_closure = function(x: number) { x * multiplier };
  const mul_result = mul_closure(5);

  respond json({ "sum": sum, "mul_result": mul_result })
}