function test_effects() {
    const db_args = ["SELECT id, name FROM users WHERE id = ?", 42];
    const log_args = ["Testing Effects system"];
    const http_args = ["https://api.example.com/test", "GET"];
    const db_result = DbRead(db_args[0], db_args[1]);
    const log_result = Log(log_args[0]);
    const http_result = HttpOut(http_args[0], http_args[1]);
    {
        "db_result": db_result,
        "log_result": log_result,
        "http_result": http_result,
        "effects_used": ["DbRead", "Log", "HttpOut"]
    }
}

api GET "/effects" uses { DbRead, Log, HttpOut } {
  const result = test_effects()
  respond json(result)
}
  const result = test_effects();
  respond json(result)
}