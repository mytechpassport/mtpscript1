api GET "/test-composites" uses {} {
  const p = { "name": "Alice", "age": 30 };
  const empty_p = { "name": "", "age": 0 };
  const nested = { "inner": p, "list": [1, 2, 3] };
  const empty_nested = { "inner": empty_p, "list": [] };
  const has_some = true;
  const has_none = false;
  const is_ok = "success";
  const is_err = "fail";
  respond json({
    "person": p,
    "empty_person": empty_p,
    "nested": nested,
    "empty_nested": empty_nested,
    "has_some": has_some,
    "has_none": has_none,
    "is_ok": is_ok,
    "is_err": is_err
  })
}