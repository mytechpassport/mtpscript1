api GET "/test-control-flow" uses {} {
  const if_positive = if (5 > 0) { "positive" } else { "non-positive" };
  const if_negative = if (-1 > 0) { "positive" } else { "non-positive" };
  const match_ok_result = 20;
  const match_err_result = 0;
  respond json({ "if_positive": if_positive, "if_negative": if_negative, "match_ok_result": match_ok_result, "match_err_result": match_err_result })
}