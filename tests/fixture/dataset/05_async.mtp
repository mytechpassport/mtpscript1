function test_async_operations() {
    const promise = Async.create("http_request");
    const result = await Async.wait(promise, "response_data");
    const promise2 = Async.create("database_query");
    const result2 = await Async.wait(promise2, "db_result");
    {
        "async_result": result,
        "db_result": result2,
        "promises_created": [promise, promise2],
        "async_operations": ["create", "wait"]
    }
}

api GET "/async" uses { Async } {
  const async_result = test_async_operations();
  respond json({
      "async_test": "completed",
      "result": async_result
  })
}
