function gas_intensive_computation(iterations: number) {
    if (iterations == 0) { 0 } else { gas_intensive_computation(iterations - 1) + 1 }
}

api GET "/gas" uses {} {
  // Each recursive call consumes ~20 gas (function call + comparison + arithmetic)
  // With 10M gas limit, ~500k iterations will exhaust gas
  const result = gas_intensive_computation(1000000);
  respond json({
      "computation": result,
      "gas_features": {
          "metering": "enabled",
          "limits": "enforced",
          "exhaustion": "deterministic_error"
      }
  })
}
